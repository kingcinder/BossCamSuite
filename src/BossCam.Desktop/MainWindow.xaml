                                        <Button Width="120" Click="BrowseScreenshotStorage_Click">Browse</Button>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Width="170" Margin="0,0,8,8" Click="StartRecording_Click">Start Recording</Button>
                                        <Button Width="170" Margin="0,0,8,8" Click="StopRecording_Click">Stop Recording</Button>
                                        <Button Width="170" Margin="0,0,8,8" Click="RefreshRecordingIndex_Click">Refresh Index</Button>
                                        <Button Width="170" Margin="0,0,8,8" Click="ExportRecentClip_Click">Export Recent Clip</Button>
                                    </WrapPanel>

                                    <TextBlock Text="NVR Playback Search" FontWeight="SemiBold" Margin="0,8,0,8"/>
