                                </WrapPanel>

                                <TabControl Grid.Row="2">
                                    <TabItem Header="Truth Maps">
                                        <DataGrid ItemsSource="{Binding ValidationMatrix}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="3*" IsReadOnly="True"/>
                                                <DataGridCheckBoxColumn Header="Read" Binding="{Binding ReadVerified}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="Write" Binding="{Binding WriteVerified}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="Persist" Binding="{Binding PersistsAfterReboot}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                                <DataGridTextColumn Header="Risk" Binding="{Binding DisruptionClass}" Width="*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Endpoint Surface">
                                        <Grid Margin="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="2*"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <DataGrid Grid.Row="0" ItemsSource="{Binding EndpointSurfaceRows}" SelectedItem="{Binding SelectedEndpointSurface}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Family" Binding="{Binding Family}" Width="1.1*"/>
                                                    <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.3*"/>
                                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="0.8*"/>
                                                    <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2.2*"/>
                                                    <DataGridCheckBoxColumn Header="Write" Binding="{Binding Writable}" Width="0.8*"/>
                                                    <DataGridCheckBoxColumn Header="Expert" Binding="{Binding ExpertOnly}" Width="0.8*"/>
                                                    <DataGridTextColumn Header="Risk" Binding="{Binding DisruptionClass}" Width="1.1*"/>
                                                    <DataGridTextColumn Header="Truth" Binding="{Binding TruthState}" Width="0.9*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <WrapPanel Grid.Row="2" Margin="0,0,0,4">
                                                <Button Margin="0,0,8,0" Padding="10,5" Click="RefreshEndpointSurface_Click">Refresh Endpoint Surface</Button>
                                                <Button Margin="0,0,8,0" Padding="10,5" Click="ResetEndpointPayload_Click">Reset Payload</Button>
                                                <Button Padding="10,5" Click="ExecuteEndpointSurface_Click" IsEnabled="{Binding CanExecuteSelectedEndpoint}" Content="{Binding SelectedEndpointExecutionLabel}"/>
                                                <TextBlock Margin="12,5,0,0" Text="{Binding SelectedEndpointHint}" Foreground="#C4D4E5" TextWrapping="Wrap"/>
                                            </WrapPanel>
                                            <Grid Grid.Row="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <GroupBox Header="Current Payload" Foreground="#F2F4F7">
                                                    <TextBox Text="{Binding EndpointCurrentPayloadText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                                </GroupBox>
                                                <GroupBox Grid.Column="2" Header="Editable Payload" Foreground="#F2F4F7">
                                                    <TextBox Text="{Binding EndpointEditablePayloadText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                                </GroupBox>
                                            </Grid>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Composite Coverage">
                                        <Grid Margin="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Bounded permutation coverage for the structured operator editors. Freeform values are counted as validated semantic bundles instead of infinite raw combinations." Foreground="#C4D4E5" TextWrapping="Wrap"/>
                                            <DataGrid Grid.Row="2" ItemsSource="{Binding CompositeCoverageRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="System" Binding="{Binding SystemName}" Width="1.4*"/>
                                                    <DataGridTextColumn Header="Class" Binding="{Binding Classification}" Width="1.1*"/>
                                                    <DataGridTextColumn Header="Valid States" Binding="{Binding ValidStateCount}" Width="0.8*"/>
                                                    <DataGridTextColumn Header="Bounded By" Binding="{Binding BoundedBy}" Width="2.4*"/>
                                                    <DataGridTextColumn Header="Rules" Binding="{Binding Rules}" Width="2.4*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Inventory">
                                        <DataGrid ItemsSource="{Binding ControlPointInventoryRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Family" Binding="{Binding Family}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Type" Binding="{Binding ControlType}" Width="1.3*"/>
                                                <DataGridTextColumn Header="Primitive" Binding="{Binding PrimitiveType}" Width="1.1*"/>
                                                <DataGridTextColumn Header="State" Binding="{Binding ReadWriteState}" Width="1.3*"/>
                                                <DataGridTextColumn Header="Widget" Binding="{Binding RecommendedWidget}" Width="1.1*"/>
                                                <DataGridCheckBoxColumn Header="Normal UI" Binding="{Binding NormalUiEligible}" Width="0.9*"/>
                                                <DataGridCheckBoxColumn Header="Mismatch" Binding="{Binding ExistingWidgetMismatch}" Width="0.9*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Write Shape" Binding="{Binding WriteShape}" Width="1.8*"/>
                                                <DataGridTextColumn Header="Blocker" Binding="{Binding ExactBlocker}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Classifications">
                                        <DataGrid ItemsSource="{Binding PromotedImageRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Class" Binding="{Binding Classification}" Width="1.3*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding SourceEndpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Semantic">
                                        <DataGrid ItemsSource="{Binding SemanticHistoryRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.4*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.8*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Transcripts">
                                        <TextBox Text="{Binding TranscriptPreview}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                    </TabItem>
                                    <TabItem Header="Raw JSON">
                                        <TextBox Text="{Binding DiagnosticsText}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Padding="12,8" CornerRadius="8" Background="{Binding ToastBackground}" Visibility="{Binding ToastVisibility}">
                    <TextBlock Text="{Binding ToastMessage}" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
</Window>




