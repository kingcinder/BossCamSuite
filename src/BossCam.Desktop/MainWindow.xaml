                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Border Padding="12" Margin="0,0,0,12" CornerRadius="10" Background="#20313E">
                                            <TextBlock Foreground="#FFF3D7C7" Text="{Binding NetworkOperatorStatus}" TextWrapping="Wrap"/>
