<Window x:Class="BossCam.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BossCamSuite" Height="900" Width="1500" Background="#101820" Foreground="#F2EAD3">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Padding="14" CornerRadius="18" Background="#17232E">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="BossCamSuite" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,16" Text="5523-w control suite / VMS shell" Foreground="#D8C7A7" />
                    <WrapPanel Margin="0,0,0,16">
                        <Button Margin="0,0,8,8" Padding="12,6" Click="RefreshDevices_Click">Load Store</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="DiscoverDevices_Click">Discover</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="ProbeSelected_Click">Probe</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="LoadProtocols_Click">Protocols</Button>
                    </WrapPanel>
                    <TextBlock Text="Devices" FontSize="18" FontWeight="Medium" Margin="0,0,0,8" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" DisplayMemberPath="DisplayName" SelectionChanged="Devices_SelectionChanged" Background="#0E171E" BorderThickness="0" />
            </DockPanel>
        </Border>
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="16" CornerRadius="18" Background="#A53D2C">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Selected Device" FontSize="16" FontWeight="Medium" />
                        <TextBlock Margin="0,8,0,2" Text="{Binding SelectedDevice.DisplayName, TargetNullValue=No device selected}" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedDevice.IpAddress, StringFormat=IP: {0}, TargetNullValue=IP: -}" />
                        <TextBlock Text="{Binding SelectedDevice.EseeId, StringFormat=ESEE: {0}, TargetNullValue=ESEE: -}" />
                        <TextBlock Text="{Binding SelectedDevice.DeviceType, StringFormat=Type: {0}, TargetNullValue=Type: -}" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Margin="0,0,8,8" Padding="12,6" Click="LoadSettings_Click">Settings</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="LoadSources_Click">Sources</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="LoadAudit_Click">Audit</Button>
                        <Button Margin="0,0,8,8" Padding="12,6" Click="LoadFirmware_Click">Firmware</Button>
                    </WrapPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="16" CornerRadius="18" Background="#17232E">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Video Sources" FontSize="18" FontWeight="Medium" Margin="0,0,0,8" />
                        <ListBox ItemsSource="{Binding Sources}" DisplayMemberPath="Url" Background="#0E171E" BorderThickness="0" />
                    </DockPanel>
                </Border>
                <Border Grid.Column="2" Padding="16" CornerRadius="18" Background="#17232E">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Diagnostics" FontSize="18" FontWeight="Medium" Margin="0,0,0,8" />
                        <TextBox Text="{Binding DiagnosticsText}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
