<Window x:Class="BossCam.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BossCamSuite"
        Height="980"
        Width="1700"
        Background="#0F1720"
        Foreground="#F2F4F7">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" CornerRadius="12" Background="#17232E">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="BossCamSuite" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Camera Settings" Foreground="#CFD7DE" Margin="0,4,0,12"/>
                    <WrapPanel>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="LoadStore_Click">Load Cameras</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="Discover_Click">Discover</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshSelected_Click">Refresh</Button>
                    </WrapPanel>
                    <TextBlock Text="Cameras" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,8"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" DisplayMemberPath="DisplayName" SelectionChanged="Devices_SelectionChanged" Background="#0E171E" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="12" CornerRadius="12" Background="#2B3C4B">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=No camera selected}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedDevice.IpAddress, StringFormat=IP: {0}, TargetNullValue=IP: -}"/>
                        <TextBlock Text="{Binding SelectedDevice.FirmwareVersion, StringFormat=Firmware: {0}, TargetNullValue=Firmware: -}"/>
                        <TextBlock Text="{Binding SelectedDevice.HardwareModel, StringFormat=Model: {0}, TargetNullValue=Model: -}"/>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding DirtyStateText}" FontWeight="SemiBold" Margin="0,0,18,0"/>
                            <TextBlock Text="{Binding LastSyncText}" Foreground="#D5DEE7"/>
                        </WrapPanel>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshSelected_Click">Refresh</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyValidated_Click">Save Changes</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyExpert_Click">Advanced Apply</Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Border Padding="10" CornerRadius="12" Background="#17232E">
                    <TabControl>
                        <TabItem Header="Camera">
                            <StackPanel Margin="8">
                                <TextBlock Text="Camera Identity" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Name" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.DisplayName}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IP Address" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.IpAddress}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Model" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.HardwareModel}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Firmware" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.FirmwareVersion}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8" Visibility="{Binding CameraSerialVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Serial" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding CameraSerial}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8" Visibility="{Binding CameraMacVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MAC" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding CameraMac}" IsReadOnly="True"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Image">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageBrightnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Brightness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="{Binding ImageBrightnessMin}" Maximum="{Binding ImageBrightnessMax}" Value="{Binding ImageBrightnessSlider}" IsEnabled="{Binding CanEditImageBrightness}" ToolTip="{Binding ImageBrightnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageBrightness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageContrastVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Contrast" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageContrastSlider}" IsEnabled="{Binding CanEditImageContrast}" ToolTip="{Binding ImageContrastReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageContrast}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageSaturationVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Saturation" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageSaturationSlider}" IsEnabled="{Binding CanEditImageSaturation}" ToolTip="{Binding ImageSaturationReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageSaturation}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageSharpnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sharpness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageSharpnessSlider}" IsEnabled="{Binding CanEditImageSharpness}" ToolTip="{Binding ImageSharpnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageSharpness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageManualSharpnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Manual Sharpness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ImageManualSharpnessSlider}" IsEnabled="{Binding CanEditImageManualSharpness}" ToolTip="{Binding ImageManualSharpnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageManualSharpness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageHueVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Hue" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageHueSlider}" IsEnabled="{Binding CanEditImageHue}" ToolTip="{Binding ImageHueReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageHue}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageGammaVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gamma" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageGammaSlider}" IsEnabled="{Binding CanEditImageGamma}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageGamma}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageDenoiseVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Denoise" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="5" Value="{Binding ImageDenoiseSlider}" IsEnabled="{Binding CanEditImageDenoise}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageDenoise}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageWdrStrengthVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="WDR Strength" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="1" Maximum="5" Value="{Binding ImageWdrStrengthSlider}" IsEnabled="{Binding CanEditImageWdrStrength}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageWdrStrength}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageWhiteLightVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="White Light" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageWhiteLightSlider}" IsEnabled="{Binding CanEditImageWhiteLight}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageWhiteLight}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageInfraredVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Infrared" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageInfraredSlider}" IsEnabled="{Binding CanEditImageInfrared}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageInfrared}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageOsdVisibility}">
                                        <TextBlock Width="140" Text="OSD Label" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding ImageOsd}" IsEnabled="{Binding CanEditImageOsd}"/>
                                    </WrapPanel>

                                    <CheckBox Content="Mirror" Margin="0,0,0,8" IsChecked="{Binding ImageMirror}" IsEnabled="{Binding CanEditImageMirror}" Visibility="{Binding ImageMirrorVisibility}" ToolTip="{Binding ImageMirrorReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                    <CheckBox Content="Flip" Margin="0,0,0,8" IsChecked="{Binding ImageFlip}" IsEnabled="{Binding CanEditImageFlip}" Visibility="{Binding ImageFlipVisibility}" ToolTip="{Binding ImageFlipReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>

                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageDayNightVisibility}">
                                        <TextBlock Width="140" Text="Day/Night" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoDayNightOptions}" SelectedItem="{Binding VideoDayNight}" IsEnabled="{Binding CanEditImageDayNight}" ToolTip="{Binding ImageDayNightReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageIrModeVisibility}">
                                        <TextBlock Width="140" Text="IR Mode" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoIrModeOptions}" SelectedItem="{Binding VideoIrMode}" IsEnabled="{Binding CanEditImageIrMode}" ToolTip="{Binding ImageIrModeReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageIrCutVisibility}">
                                        <TextBlock Width="140" Text="IR Cut" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoIrCutOptions}" SelectedItem="{Binding VideoIrCut}" IsEnabled="{Binding CanEditImageIrCut}" ToolTip="{Binding ImageIrCutReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageIrCutMethodVisibility}">
                                        <TextBlock Width="140" Text="IR Cut Method" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoIrCutMethodOptions}" SelectedItem="{Binding VideoIrCutMethod}" IsEnabled="{Binding CanEditImageIrCutMethod}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageSceneModeVisibility}">
                                        <TextBlock Width="140" Text="Scene Mode" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoSceneModeOptions}" SelectedItem="{Binding VideoSceneMode}" IsEnabled="{Binding CanEditImageSceneMode}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageExposureVisibility}">
                                        <TextBlock Width="140" Text="Exposure" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoExposureOptions}" SelectedItem="{Binding VideoExposure}" IsEnabled="{Binding CanEditImageExposure}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageAwbVisibility}">
                                        <TextBlock Width="140" Text="AWB" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoAwbOptions}" SelectedItem="{Binding VideoAwb}" IsEnabled="{Binding CanEditImageAwb}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageLowlightVisibility}">
                                        <TextBlock Width="140" Text="Lowlight" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoLowlightOptions}" SelectedItem="{Binding VideoLowlight}" IsEnabled="{Binding CanEditImageLowlight}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Stream">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamResolutionVisibility}">
                                        <TextBlock Width="140" Text="Resolution" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoResolutionOptions}" SelectedItem="{Binding VideoResolution}" IsEnabled="{Binding CanEditVideoResolution}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamCodecVisibility}">
                                        <TextBlock Width="140" Text="Codec" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoCodecOptions}" SelectedItem="{Binding VideoCodec}" IsEnabled="{Binding CanEditVideoCodec}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamProfileVisibility}">
                                        <TextBlock Width="140" Text="Profile" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoProfileOptions}" SelectedItem="{Binding VideoProfile}" IsEnabled="{Binding CanEditVideoProfile}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamBitrateModeVisibility}">
                                        <TextBlock Width="140" Text="Bitrate Mode" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoBitrateModeOptions}" SelectedItem="{Binding VideoBitrateMode}" IsEnabled="{Binding CanEditVideoBitrateMode}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamDefinitionVisibility}">
                                        <TextBlock Width="140" Text="Definition" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding VideoDefinitionOptions}" SelectedItem="{Binding VideoDefinition}" IsEnabled="{Binding CanEditVideoDefinition}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamBitrateVisibility}">
                                        <TextBlock Width="140" Text="Bitrate (kbps)" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding VideoBitrate}" IsEnabled="{Binding CanEditStreamBitrate}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamFpsVisibility}">
                                        <TextBlock Width="140" Text="FPS" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding VideoFrameRate}" IsEnabled="{Binding CanEditStreamFrameRate}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamKeyframeVisibility}">
                                        <TextBlock Width="140" Text="Keyframe" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding VideoKeyframeInterval}" IsEnabled="{Binding CanEditStreamKeyframe}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Network">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkIpVisibility}">
                                        <TextBlock Width="140" Text="IP" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkIp}" IsEnabled="{Binding CanEditNetworkIp}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkNetmaskVisibility}">
                                        <TextBlock Width="140" Text="Netmask" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkNetmask}" IsEnabled="{Binding CanEditNetworkNetmask}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkGatewayVisibility}">
                                        <TextBlock Width="140" Text="Gateway" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkGateway}" IsEnabled="{Binding CanEditNetworkGateway}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkDnsVisibility}">
                                        <TextBlock Width="140" Text="DNS" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkDns}" IsEnabled="{Binding CanEditNetworkDns}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkPortVisibility}">
                                        <TextBlock Width="140" Text="HTTP Port" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkPort}" IsEnabled="{Binding CanEditNetworkPort}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkDhcpModeVisibility}">
                                        <TextBlock Width="140" Text="DHCP" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding NetworkDhcpMode}" IsEnabled="{Binding CanEditNetworkDhcpMode}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkEseeVisibility}">
                                        <TextBlock Width="140" Text="ESEE Enabled" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding NetworkEseeEnabled}" IsEnabled="{Binding CanEditNetworkEseeEnabled}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkNtpEnabledVisibility}">
                                        <TextBlock Width="140" Text="NTP Enabled" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding NetworkNtpEnabled}" IsEnabled="{Binding CanEditNetworkNtpEnabled}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkNtpServerVisibility}">
                                        <TextBlock Width="140" Text="NTP Server" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkNtpServer}" IsEnabled="{Binding CanEditNetworkNtpServer}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkEseeIdVisibility}">
                                        <TextBlock Width="140" Text="ESEE ID" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding NetworkEseeId}" IsReadOnly="True"/>
                                    </WrapPanel>
                                    <Separator Margin="0,8,0,8"/>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessModeVisibility}">
                                        <TextBlock Width="140" Text="WiFi Mode" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding WirelessModeOptions}" SelectedItem="{Binding WirelessMode}" IsEnabled="{Binding CanEditWirelessMode}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApModeVisibility}">
                                        <TextBlock Width="140" Text="AP Mode" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding WirelessApModeOptions}" SelectedItem="{Binding WirelessApMode}" IsEnabled="{Binding CanEditWirelessApMode}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApSsidVisibility}">
                                        <TextBlock Width="140" Text="AP SSID" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding WirelessApSsid}" IsEnabled="{Binding CanEditWirelessApSsid}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApPskVisibility}">
                                        <TextBlock Width="140" Text="AP PSK" VerticalAlignment="Center"/>
                                        <PasswordBox Width="220" PasswordChanged="WirelessPskPasswordChanged"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApChannelVisibility}">
                                        <TextBlock Width="140" Text="AP Channel" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding WirelessApChannel}" IsEnabled="{Binding CanEditWirelessApChannel}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Users">
                            <StackPanel Margin="8">
                                <TextBlock Text="Users" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ListBox Height="120" ItemsSource="{Binding UserList}" Margin="0,0,0,10"/>
                                <WrapPanel Margin="0,0,0,8">
                                    <TextBlock Width="140" Text="Username" VerticalAlignment="Center"/>
                                    <TextBox Width="220" Text="{Binding PasswordChangeUsername}"/>
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,8">
                                    <TextBlock Width="140" Text="New Password" VerticalAlignment="Center"/>
                                    <PasswordBox Width="220" PasswordChanged="PasswordChangePasswordChanged"/>
                                </WrapPanel>
                                <Button Width="180" Click="ApplyPasswordChange_Click">Apply Password Change</Button>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Motion/Alarm">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding MotionEnabledVisibility}">
                                        <TextBlock Width="140" Text="Motion Enabled" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding MotionEnabled}" IsEnabled="{Binding CanEditMotionEnabled}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding MotionTypeVisibility}">
                                        <TextBlock Width="140" Text="Motion Type" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" ItemsSource="{Binding MotionTypeOptions}" SelectedItem="{Binding MotionType}" IsEnabled="{Binding CanEditMotionType}"/>
                                    </WrapPanel>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding MotionSensitivityVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sensitivity" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding MotionSensitivitySlider}" IsEnabled="{Binding CanEditMotionSensitivity}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MotionSensitivity}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding MotionAlarmDurationVisibility}">
                                        <TextBlock Width="140" Text="Motion Alarm (s)" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding MotionAlarmDuration}" IsEnabled="{Binding CanEditMotionAlarmDuration}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding MotionAlarmVisibility}">
                                        <TextBlock Width="140" Text="Motion Trigger" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding MotionAlarm}" IsEnabled="{Binding CanEditMotionAlarm}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding MotionBuzzerVisibility}">
                                        <TextBlock Width="140" Text="Motion Buzzer" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding MotionBuzzer}" IsEnabled="{Binding CanEditMotionBuzzer}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoLossAlarmDurationVisibility}">
                                        <TextBlock Width="140" Text="Video Loss (s)" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding VideoLossAlarmDuration}" IsEnabled="{Binding CanEditVideoLossAlarmDuration}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoLossAlarmVisibility}">
                                        <TextBlock Width="140" Text="Video Loss Trigger" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding VideoLossAlarm}" IsEnabled="{Binding CanEditVideoLossAlarm}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoLossBuzzerVisibility}">
                                        <TextBlock Width="140" Text="Video Loss Buzzer" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding VideoLossBuzzer}" IsEnabled="{Binding CanEditVideoLossBuzzer}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskEnabledVisibility}">
                                        <TextBlock Width="140" Text="Privacy Mask" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding PrivacyMaskEnabled}" IsEnabled="{Binding CanEditPrivacyMaskEnabled}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskXVisibility}">
                                        <TextBlock Width="140" Text="Mask X" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding PrivacyMaskX}" IsEnabled="{Binding CanEditPrivacyMaskX}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskYVisibility}">
                                        <TextBlock Width="140" Text="Mask Y" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding PrivacyMaskY}" IsEnabled="{Binding CanEditPrivacyMaskY}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskWidthVisibility}">
                                        <TextBlock Width="140" Text="Mask Width" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding PrivacyMaskWidth}" IsEnabled="{Binding CanEditPrivacyMaskWidth}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskHeightVisibility}">
                                        <TextBlock Width="140" Text="Mask Height" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding PrivacyMaskHeight}" IsEnabled="{Binding CanEditPrivacyMaskHeight}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmInputStateVisibility}">
                                        <TextBlock Width="140" Text="Alarm Input" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding AlarmInputState}" IsEnabled="{Binding CanEditAlarmInputState}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmOutputStateVisibility}">
                                        <TextBlock Width="140" Text="Alarm Output" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding AlarmOutputState}" IsEnabled="{Binding CanEditAlarmOutputState}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmPulseDurationVisibility}">
                                        <TextBlock Width="140" Text="Alarm Pulse (ms)" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding AlarmPulseDuration}" IsEnabled="{Binding CanEditAlarmPulseDuration}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmDurationVisibility}">
                                        <TextBlock Width="140" Text="Alarm Duration (s)" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding AlarmDuration}" IsEnabled="{Binding CanEditAlarmDuration}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmEnabledVisibility}">
                                        <TextBlock Width="140" Text="Alarm Enabled" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding AlarmEnabled}" IsEnabled="{Binding CanEditAlarmEnabled}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding AlarmBuzzerVisibility}">
                                        <TextBlock Width="140" Text="Alarm Buzzer" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding AlarmBuzzer}" IsEnabled="{Binding CanEditAlarmBuzzer}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Storage">
                            <StackPanel Margin="8">
                                <WrapPanel Margin="0,0,0,8" Visibility="{Binding SdStatusVisibility}">
                                    <TextBlock Width="140" Text="SD Status" VerticalAlignment="Center"/>
                                    <TextBox Width="220" Text="{Binding SdStatus}" IsReadOnly="True"/>
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,8" Visibility="{Binding SdMediaTypeVisibility}">
                                    <TextBlock Width="140" Text="Media Type" VerticalAlignment="Center"/>
                                    <TextBox Width="220" Text="{Binding SdMediaType}" IsReadOnly="True"/>
                                </WrapPanel>
                                <TextBlock Text="Storage state is read from camera media/search and status endpoints." Foreground="#CFD7DE" TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Maintenance">
                            <StackPanel Margin="8">
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Width="170" Margin="0,0,8,8" Click="RebootCamera_Click">Reboot</Button>
                                    <Button Width="170" Margin="0,0,8,8" Click="FactoryDefault_Click">Factory Reset</Button>
                                </WrapPanel>
                                <TextBlock Text="Firmware Upload" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <WrapPanel Margin="0,0,0,8">
                                    <TextBox Width="420" Text="{Binding FirmwareUploadPath}" IsReadOnly="True" Margin="0,0,8,8"/>
                                    <Button Width="120" Margin="0,0,8,8" Click="BrowseFirmware_Click">Browse</Button>
                                    <Button Width="140" Margin="0,0,8,8" Click="UploadFirmware_Click">Upload Firmware</Button>
                                </WrapPanel>
                                <TextBlock Text="{Binding MaintenanceState}" Foreground="#FFD27A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Advanced">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                    <ComboBox Width="170" Margin="0,0,8,8" ItemsSource="{Binding ProbeModes}" SelectedItem="{Binding SelectedProbeMode}"/>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="ProbeSelected_Click">Run Probe</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="ProbeKnownIps_Click">Probe Known IPs</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="LoadSessions_Click">Probe Sessions</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="LoadTranscripts_Click">Transcripts</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="DiscoverConstraints_Click">Discover Constraints</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="RunImageTruthSweep_Click">Image Truth Sweep</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="PromoteFixtures_Click">Promote Fixtures</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="NativeAssessment_Click">Native Gap</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshTyped_Click">Refresh Typed</Button>
                                    <ComboBox Width="170" Margin="0,0,8,8" ItemsSource="{Binding PersistenceFieldOptions}" SelectedItem="{Binding SelectedPersistenceField}"/>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="VerifyPersistence_Click">Verify Persistence</Button>
                                </WrapPanel>

                                <TabControl Grid.Row="2">
                                    <TabItem Header="Truth Maps">
                                        <DataGrid ItemsSource="{Binding ValidationMatrix}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="3*" IsReadOnly="True"/>
                                                <DataGridCheckBoxColumn Header="Read" Binding="{Binding ReadVerified}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="Write" Binding="{Binding WriteVerified}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="Persist" Binding="{Binding PersistsAfterReboot}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                                <DataGridTextColumn Header="Risk" Binding="{Binding DisruptionClass}" Width="*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Inventory">
                                        <DataGrid ItemsSource="{Binding ImageInventoryRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.4*"/>
                                                <DataGridTextColumn Header="Class" Binding="{Binding CandidateClassification}" Width="1.5*"/>
                                                <DataGridCheckBoxColumn Header="Readable" Binding="{Binding Readable}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="Writable" Binding="{Binding Writable}" Width="*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding SourceEndpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Classifications">
                                        <DataGrid ItemsSource="{Binding PromotedImageRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Class" Binding="{Binding Classification}" Width="1.3*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding SourceEndpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Semantic">
                                        <DataGrid ItemsSource="{Binding SemanticHistoryRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.4*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.8*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Transcripts">
                                        <TextBox Text="{Binding TranscriptPreview}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                    </TabItem>
                                    <TabItem Header="Raw JSON">
                                        <TextBox Text="{Binding DiagnosticsText}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Padding="12,8" CornerRadius="8" Background="{Binding ToastBackground}" Visibility="{Binding ToastVisibility}">
                    <TextBlock Text="{Binding ToastMessage}" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>




