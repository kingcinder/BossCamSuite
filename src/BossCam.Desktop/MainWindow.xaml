                                            <DataGridTextColumn Header="Probed Codec" Binding="{Binding ProbedCodec}" Width="1*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Declared Res" Binding="{Binding DeclaredResolution}" Width="1*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Probed Res" Binding="{Binding ProbedResolution}" Width="1*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="FPS" Binding="{Binding ProbedFps}" Width="0.7*" IsReadOnly="True"/>
