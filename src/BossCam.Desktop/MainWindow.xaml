<Window x:Class="BossCam.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BossCamSuite"
        Height="980"
        Width="1700"
        Background="#101820"
        Foreground="#F2EAD3">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" CornerRadius="12" Background="#17232E">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="BossCamSuite" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="5523-w settings/control operator console" Foreground="#D8C7A7" Margin="0,4,0,12"/>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Margin="0,0,8,8" Padding="10,5" Click="LoadStore_Click">Load Store</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="Discover_Click">Discover</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshTyped_Click">Refresh Typed</Button>
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <ComboBox Width="180" Margin="0,0,8,8" ItemsSource="{Binding ProbeModes}" SelectedItem="{Binding SelectedProbeMode}" />
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ProbeSelected_Click">Run Probe</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ProbeKnownIps_Click">Probe 3 Live IPs</Button>
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Margin="0,0,8,8" Padding="10,5" Click="LoadSessions_Click">Probe Sessions</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="LoadTranscripts_Click">Transcripts</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="DiscoverConstraints_Click">Discover Constraints</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="PromoteFixtures_Click">Promote Fixtures</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="NativeAssessment_Click">Native Gap</Button>
                    </WrapPanel>
                    <TextBlock Text="Devices" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" DisplayMemberPath="DisplayName" SelectionChanged="Devices_SelectionChanged" Background="#0E171E" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="12" CornerRadius="12" Background="#A53D2C">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=No device selected}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedDevice.IpAddress, StringFormat=IP: {0}, TargetNullValue=IP: -}"/>
                        <TextBlock Text="{Binding SelectedDevice.FirmwareVersion, StringFormat=Firmware: {0}, TargetNullValue=Firmware: -}"/>
                        <TextBlock Text="{Binding SelectedDevice.HardwareModel, StringFormat=Model: {0}, TargetNullValue=Model: -}"/>
                        <TextBlock Text="{Binding HealthBadgeText}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding CapabilityBadgeText}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding FirmwareTruthBadge}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyValidated_Click">Apply Validated</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyExpert_Click">Apply Expert</Button>
                        <ComboBox Width="170" Margin="0,0,8,8" ItemsSource="{Binding PersistenceFieldOptions}" SelectedItem="{Binding SelectedPersistenceField}"/>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="VerifyPersistence_Click">Verify Persistence</Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.65*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="10" CornerRadius="12" Background="#17232E">
                    <TabControl>
                        <TabItem Header="Video/Image">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding VideoEditorNotice}" Foreground="#E5D9BF" Margin="0,0,0,10"/>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoCodecVisibility}">
                                        <TextBlock Width="140" Text="Codec" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoCodecOptions}" SelectedItem="{Binding VideoCodec}" IsEnabled="{Binding CanEditVideoCodec}"/>
                                        <TextBlock Margin="12,0,0,0" Text="{Binding VideoCodecState}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoProfileVisibility}">
                                        <TextBlock Width="140" Text="Profile" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoProfileOptions}" SelectedItem="{Binding VideoProfile}" IsEnabled="{Binding CanEditVideoProfile}"/>
                                        <TextBlock Margin="12,0,0,0" Text="{Binding VideoProfileState}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoResolutionVisibility}">
                                        <TextBlock Width="140" Text="Resolution" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoResolutionOptions}" SelectedItem="{Binding VideoResolution}" IsEnabled="{Binding CanEditVideoResolution}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoDayNightVisibility}">
                                        <TextBlock Width="140" Text="Day/Night" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoDayNightOptions}" SelectedItem="{Binding VideoDayNight}" IsEnabled="{Binding CanEditVideoDayNight}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoWdrVisibility}">
                                        <TextBlock Width="140" Text="WDR" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoWdrOptions}" SelectedItem="{Binding VideoWdr}" IsEnabled="{Binding CanEditVideoWdr}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoIrCutVisibility}">
                                        <TextBlock Width="140" Text="IR Cut" VerticalAlignment="Center"/>
                                        <ComboBox Width="180" ItemsSource="{Binding VideoIrCutOptions}" SelectedItem="{Binding VideoIrCut}" IsEnabled="{Binding CanEditVideoIrCut}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoBitrateVisibility}">
                                        <TextBlock Width="140" Text="Bitrate (kbps)" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding VideoBitrate}"/>
                                        <Slider Width="200" Margin="10,0,0,0" Minimum="{Binding VideoBitrateMin}" Maximum="{Binding VideoBitrateMax}" Value="{Binding VideoBitrateSlider}" TickFrequency="64" IsSnapToTickEnabled="False"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding VideoFrameRateVisibility}">
                                        <TextBlock Width="140" Text="Frame Rate" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding VideoFrameRate}"/>
                                        <TextBlock Margin="12,0,0,0" Text="{Binding VideoFpsHint}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageBrightnessVisibility}">
                                        <TextBlock Width="140" Text="Brightness" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding ImageBrightness}"/>
                                        <Slider Width="200" Margin="10,0,0,0" Minimum="{Binding ImageBrightnessMin}" Maximum="{Binding ImageBrightnessMax}" Value="{Binding ImageBrightnessSlider}" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageContrastVisibility}">
                                        <TextBlock Width="140" Text="Contrast" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding ImageContrast}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageSaturationVisibility}">
                                        <TextBlock Width="140" Text="Saturation" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding ImageSaturation}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding ImageHueVisibility}">
                                        <TextBlock Width="140" Text="Hue" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding ImageHue}"/>
                                    </WrapPanel>
                                    <WrapPanel Visibility="{Binding ImageSharpnessVisibility}">
                                        <TextBlock Width="140" Text="Sharpness" VerticalAlignment="Center"/>
                                        <TextBox Width="110" Text="{Binding ImageSharpness}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Network/Wireless">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Network-changing writes can break control connectivity. Reconnect hints are shown after apply." Foreground="#FFD27A" Margin="0,0,0,10"/>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkIpVisibility}">
                                        <TextBlock Width="140" Text="IP" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding NetworkIp}" IsEnabled="{Binding CanEditNetworkIp}"/>
                                        <TextBlock Margin="12,0,0,0" Text="{Binding NetworkIpState}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkNetmaskVisibility}">
                                        <TextBlock Width="140" Text="Netmask" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding NetworkNetmask}" IsEnabled="{Binding CanEditNetworkNetmask}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkGatewayVisibility}">
                                        <TextBlock Width="140" Text="Gateway" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding NetworkGateway}" IsEnabled="{Binding CanEditNetworkGateway}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkDnsVisibility}">
                                        <TextBlock Width="140" Text="DNS" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding NetworkDns}" IsEnabled="{Binding CanEditNetworkDns}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding NetworkPortVisibility}">
                                        <TextBlock Width="140" Text="HTTP Port" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding NetworkPort}" IsEnabled="{Binding CanEditNetworkPort}"/>
                                    </WrapPanel>
                                    <Separator Margin="0,8,0,8"/>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApSsidVisibility}">
                                        <TextBlock Width="140" Text="AP SSID" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding WirelessApSsid}" IsEnabled="{Binding CanEditWirelessApSsid}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApPskVisibility}">
                                        <TextBlock Width="140" Text="AP PSK" VerticalAlignment="Center"/>
                                        <PasswordBox Width="180" PasswordChanged="WirelessPskPasswordChanged"/>
                                        <TextBlock Margin="12,0,0,0" Text="{Binding WirelessApPskState}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding WirelessApChannelVisibility}">
                                        <TextBlock Width="140" Text="AP Channel" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding WirelessApChannel}" IsEnabled="{Binding CanEditWirelessApChannel}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,6,0,6">
                                        <TextBlock Width="140" Text="Current URL" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentControlUrl}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Width="140" Text="Predicted URL" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PredictedControlUrl}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <Button Width="190" Margin="0,0,0,6" Click="RunNetworkRecovery_Click">Run Recovery Probe</Button>
                                    <TextBlock Text="{Binding NetworkRecoveryHint}" Foreground="#FFD27A" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding LastReachableUrl, StringFormat=Last Reachable URL: {0}}" Foreground="#E5D9BF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Users/Maintenance">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Users" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ListBox ItemsSource="{Binding UserList}" Height="180" Background="#0E171E" BorderThickness="0"/>
                                    <TextBlock Text="Password Change" FontWeight="SemiBold" Margin="0,10,0,6"/>
                                    <WrapPanel Margin="0,0,0,6">
                                        <TextBlock Width="120" Text="Username" VerticalAlignment="Center"/>
                                        <TextBox Width="180" Text="{Binding PasswordChangeUsername}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,6">
                                        <TextBlock Width="120" Text="New Password" VerticalAlignment="Center"/>
                                        <PasswordBox Width="180" PasswordChanged="PasswordChangePasswordChanged"/>
                                    </WrapPanel>
                                    <Button Width="160" Margin="0,6,0,0" Click="ApplyPasswordChange_Click">Apply Password Change</Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Maintenance Actions" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Button Width="180" Margin="0,0,0,8" Click="RebootCamera_Click">Reboot Camera</Button>
                                    <Button Width="180" Margin="0,0,0,8" Click="FactoryDefault_Click">Factory Default</Button>
                                    <TextBlock Text="{Binding MaintenanceState}" Foreground="#FFD27A" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Recording">
                            <StackPanel Margin="6">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="StartRecording_Click">Start Recording</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="StopRecording_Click">Stop Recording</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshRecordingIndex_Click">Refresh Index</Button>
                                    <Button Margin="0,0,8,8" Padding="10,5" Click="ExportRecentClip_Click">Export Last 10m</Button>
                                </WrapPanel>
                                <TextBlock Text="{Binding RecordingState}" Foreground="#FFD27A" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding RecordingDiagnostics}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Diagnostics/Expert">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DataGrid ItemsSource="{Binding ValidationMatrix}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="3*" IsReadOnly="True"/>
                                        <DataGridCheckBoxColumn Header="Read" Binding="{Binding ReadVerified}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="Write" Binding="{Binding WriteVerified}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="Persist" Binding="{Binding PersistsAfterReboot}" Width="*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        <DataGridTextColumn Header="Risk" Binding="{Binding DisruptionClass}" Width="*"/>
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TabControl Grid.Row="2">
                                    <TabItem Header="Field Provenance">
                                        <DataGrid ItemsSource="{Binding FieldProvenanceRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.6*"/>
                                                <DataGridTextColumn Header="Truth" Binding="{Binding TruthState}" Width="*"/>
                                                <DataGridTextColumn Header="Support" Binding="{Binding SupportState}" Width="*"/>
                                                <DataGridTextColumn Header="Validity" Binding="{Binding Validity}" Width="*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding SourceEndpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Path" Binding="{Binding RawSourcePath}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Semantic Timeline">
                                        <DataGrid ItemsSource="{Binding SemanticHistoryRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.4*"/>
                                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*"/>
                                                <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.8*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Constraints">
                                        <DataGrid ItemsSource="{Binding ConstraintRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Field" Binding="{Binding FieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Contract" Binding="{Binding ContractKey}" Width="1.8*"/>
                                                <DataGridTextColumn Header="Values" Binding="{Binding SupportedValues}" Width="2*"/>
                                                <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="*"/>
                                                <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="*"/>
                                                <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Dependencies">
                                        <DataGrid ItemsSource="{Binding DependencyRows}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Primary" Binding="{Binding PrimaryFieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Depends On" Binding="{Binding DependsOnFieldKey}" Width="*"/>
                                                <DataGridTextColumn Header="Depends Values" Binding="{Binding DependsOnValues}" Width="1.5*"/>
                                                <DataGridTextColumn Header="Allowed Values" Binding="{Binding AllowedPrimaryValues}" Width="1.7*"/>
                                                <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="*"/>
                                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="1.6*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                </TabControl>
                                <TextBox Grid.Column="2" Grid.RowSpan="3" Text="{Binding TranscriptPreview}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="2" Padding="10" CornerRadius="12" Background="#17232E">
                    <TextBox Text="{Binding DiagnosticsText}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#0E171E" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
