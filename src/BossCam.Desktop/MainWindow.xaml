                                                    <TextBlock Width="140" Text="Alarm Buzzer" VerticalAlignment="Center"/>
                                                    <CheckBox IsChecked="{Binding AlarmBuzzer}" IsEnabled="{Binding CanEditAlarmBuzzer}" VerticalAlignment="Center"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Storage">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Recording" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Margin="0,0,0,10" Foreground="#C4D4E5" Text="Operator recording controls stay separate from playback/export workflows so disruptive actions are explicit." TextWrapping="Wrap"/>
                                    <TextBlock Text="Storage Locations" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Width="170" Text="Video Recording Folder" VerticalAlignment="Center"/>
                                        <TextBox Width="520" Margin="0,0,8,0" Text="{Binding VideoRecordingStoragePath, Mode=OneWay}" IsReadOnly="True"/>
                                        <Button Width="120" Click="BrowseVideoRecordingStorage_Click">Browse</Button>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Width="170" Text="Audio Recording Folder" VerticalAlignment="Center"/>
                                        <TextBox Width="520" Margin="0,0,8,0" Text="{Binding AudioRecordingStoragePath, Mode=OneWay}" IsReadOnly="True"/>
                                        <Button Width="120" Click="BrowseAudioRecordingStorage_Click">Browse</Button>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,12">
                                        <TextBlock Width="170" Text="Screenshot Still Folder" VerticalAlignment="Center"/>
