                                                    </WrapPanel>
                                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding PrivacyMaskYVisibility}">
                                                        <TextBlock Width="140" Text="Mask Y" VerticalAlignment="Center"/>
                                                        <TextBox Width="220" Text="{Binding PrivacyMaskY}" IsEnabled="{Binding CanEditPrivacyMaskY}"/>
