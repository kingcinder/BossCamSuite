                                    <Button Width="140" Margin="0,0,8,8" Click="UploadFirmware_Click">Upload Firmware</Button>
                                </WrapPanel>
                                <TextBlock Text="{Binding MaintenanceState}" Foreground="#FFD27A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="NVR">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="190"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="10" CornerRadius="10" Background="#0E171E">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Width="110" Margin="0,0,8,0" Click="RefreshNvrJobs_Click">Jobs</Button>
                                            <Button Width="130" Margin="0,0,8,0" Click="RefreshNvrIndex_Click">Index</Button>
                                            <Button Width="130" Margin="0,0,8,0" Click="NvrHousekeeping_Click">Housekeeping</Button>
                                            <Button Width="120" Click="NvrExportClip_Click">Export</Button>
                                        </StackPanel>
                                        <WrapPanel>
                                            <Button Width="90" Margin="0,0,8,8" Click="NvrLiveMode_Click">Live</Button>
                                            <Button Width="90" Margin="0,0,8,8" Click="NvrPlaybackMode_Click">Playback</Button>
                                            <TextBlock Text="{Binding NvrModeText}" VerticalAlignment="Center" Margin="0,0,14,8" Foreground="#CFD7DE"/>
                                            <TextBlock Text="Layout" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <Button Width="42" Margin="0,0,4,8" Tag="1" Click="NvrLayout_Click">1</Button>
                                            <Button Width="42" Margin="0,0,4,8" Tag="3" Click="NvrLayout_Click">3</Button>
                                            <Button Width="42" Margin="0,0,4,8" Tag="4" Click="NvrLayout_Click">4</Button>
                                            <Button Width="42" Margin="0,0,4,8" Tag="5" Click="NvrLayout_Click">5</Button>
                                            <Button Width="42" Margin="0,0,4,8" Tag="6" Click="NvrLayout_Click">6</Button>
                                            <Button Width="42" Margin="0,0,14,8" Tag="9" Click="NvrLayout_Click">9</Button>
                                            <Button Width="140" Margin="0,0,8,8" Click="AssignSelectedCameraToNvr_Click">Bind Camera</Button>
                                            <Button Width="120" Margin="0,0,8,8" Click="StartNvrLive_Click">Start Live</Button>
                                            <Button Width="120" Margin="0,0,8,8" Click="StopSelectedNvrTile_Click">Stop Tile</Button>
                                            <Button Width="130" Margin="0,0,8,8" Click="RefreshNvrSources_Click">Sources</Button>
                                        </WrapPanel>
                                    </DockPanel>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="330"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid x:Name="NvrTileGrid" Background="#071018"/>

                                    <Border Grid.Column="2" Padding="10" CornerRadius="10" Background="#0E171E">
                                        <StackPanel>
                                            <TextBlock Text="Playback Time" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <DatePicker SelectedDate="{Binding PlaybackDate}" Margin="0,0,0,8"/>
                                            <WrapPanel Margin="0,0,0,8">
                                                <TextBlock Width="80" Text="Clock" VerticalAlignment="Center"/>
                                                <TextBox Width="110" Text="{Binding PlaybackTime, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Width="70" Margin="10,0,0,0" Text="Minutes" VerticalAlignment="Center"/>
                                                <TextBox Width="45" Text="{Binding PlaybackWindowMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                                            </WrapPanel>
                                            <WrapPanel Margin="0,0,0,12">
                                                <Button Width="130" Margin="0,0,8,8" Click="NvrFindPlayback_Click">Find</Button>
                                                <Button Width="130" Margin="0,0,8,8" Click="NvrPlayPlayback_Click">Play</Button>
                                            </WrapPanel>

                                            <TextBlock Text="Network Sources" FontWeight="SemiBold" Margin="0,0,0,8"/>
