                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamAudioBitrateVisibility}">
                                        <TextBlock Width="140" Text="Audio Bitrate" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding StreamAudioBitrate}" IsEnabled="{Binding CanEditStreamAudioBitrate}"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,0,0,8" Visibility="{Binding StreamAudioSampleRateVisibility}">
                                        <TextBlock Width="140" Text="Audio Sample Rate" VerticalAlignment="Center"/>
                                        <TextBox Width="220" Text="{Binding StreamAudioSampleRate}" IsEnabled="{Binding CanEditStreamAudioSampleRate}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Network">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
