                        <TabItem Header="Stream">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <Border Padding="10" Margin="0,0,0,10" CornerRadius="8" Background="#20313E">
                                        <StackPanel>
                                            <TextBlock Text="{Binding CredentialStatusText}" Foreground="#FFF3D7C7" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding EndpointDriftWarning}" Foreground="#FFFFC36A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding PtzServiceText}" Foreground="#C4D4E5" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Refresh Endpoint Truth" Click="RefreshEndpointTruth_Click" Margin="0,0,8,0"/>
                                                <Button Content="Open Live Feed" Click="OpenLiveFeed_Click" Margin="0,0,8,0"/>
