                                                <DataGridTextColumn Header="Device" Binding="{Binding DeviceId}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70" IsReadOnly="True"/>
                                                <DataGridCheckBoxColumn Header="Run" Binding="{Binding IsRunning}" Width="55" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                </Grid>
                            </Grid>
                        </TabItem>

