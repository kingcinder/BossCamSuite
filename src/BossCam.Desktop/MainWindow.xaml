                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="80" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="50" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*" IsReadOnly="True"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock Text="NVR Diagnostics" FontWeight="SemiBold" Margin="0,12,0,8"/>
                                            <TextBox Height="120" Text="{Binding NvrDiagnostics}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Background="#050A0F" BorderThickness="0" Foreground="#F2EAD3" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <GroupBox Header="Indexed Segments" Foreground="#F2F4F7">
                                        <DataGrid ItemsSource="{Binding NvrRecordingSegments}" SelectedItem="{Binding SelectedNvrRecordingSegment}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="1.2*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="End" Binding="{Binding EndTime}" Width="1.2*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="MB" Binding="{Binding SizeBytes}" Width="0.5*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="2.5*" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                    <GroupBox Grid.Column="2" Header="Recording Jobs" Foreground="#F2F4F7">
                                        <DataGrid ItemsSource="{Binding NvrRecordingJobs}" AutoGenerateColumns="False" Background="#0E171E" BorderThickness="0">
