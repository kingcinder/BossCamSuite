<Window x:Class="BossCam.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BossCamSuite"
        Icon="Assets/BossCamSuite.ico"
        Height="980"
        Width="1700"
        Background="#050506"
        Foreground="#F2F4F7">
    <Window.Resources>
        <ImageBrush x:Key="BossCamThemeImage"
                    ImageSource="Assets/BossCamSuite.png"
                    Stretch="UniformToFill"
                    Opacity="0.18"/>
        <SolidColorBrush x:Key="ThemePanelBrush" Color="#CC0B090B"/>
        <SolidColorBrush x:Key="ThemePanelAltBrush" Color="#D9161214"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#66FF5A1F"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFF6A1F"/>
        <SolidColorBrush x:Key="ThemeAccentMutedBrush" Color="#CCAC2F11"/>
        <SolidColorBrush x:Key="ThemeTextMutedBrush" Color="#FFE0C9C0"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFF2EA"/>
            <Setter Property="Background" Value="#CC1A1010"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E6331713"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFFFA33E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF4A160D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#B30B090B"/>
            <Setter Property="BorderBrush" Value="#55FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#99111316"/>
                    <Setter Property="Foreground" Value="#FFF3E4D6"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80202226"/>
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                    <Setter Property="BorderBrush" Value="#554A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#B30B090B"/>
            <Setter Property="BorderBrush" Value="#55FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80202226"/>
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                    <Setter Property="BorderBrush" Value="#554A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#B30B090B"/>
            <Setter Property="BorderBrush" Value="#55FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFFFF5EE"/>
                        <Setter Property="Background" Value="#FF121518"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#AA5A1F0F"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FFB9AEA5"/>
                                <Setter Property="Background" Value="#80202226"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80202226"/>
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                    <Setter Property="BorderBrush" Value="#554A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#B30B090B"/>
            <Setter Property="BorderBrush" Value="#55FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80202226"/>
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                    <Setter Property="BorderBrush" Value="#554A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#B30B090B"/>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="#FF121518"/>
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FFFFA33E"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#73080507"/>
            <Setter Property="BorderBrush" Value="#44FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#551A0A07"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#55FF5A1F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#AA3B120B"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFFF6A1F"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFE0C9C0"/>
            <Setter Property="Background" Value="#660A0809"/>
            <Setter Property="BorderBrush" Value="#33FF5A1F"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#FFFFF5EE"/>
                    <Setter Property="Background" Value="#AA3B120B"/>
                    <Setter Property="BorderBrush" Value="#FFFF6A1F"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FF9E9089"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#44FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#66080507"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#73080507"/>
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="BorderBrush" Value="#44FF5A1F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#22FF5A1F"/>
            <Setter Property="VerticalGridLinesBrush" Value="#00000000"/>
            <Setter Property="RowBackground" Value="#22000000"/>
            <Setter Property="AlternatingRowBackground" Value="#33100606"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Setter Property="Background" Value="#AA240E0A"/>
            <Setter Property="BorderBrush" Value="#55FF5A1F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#AA5A1F0F"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FFB9AEA5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#FFFFF5EE"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#AA5A1F0F"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Background="#050506"/>
        <Border Background="{StaticResource BossCamThemeImage}"/>
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EE040405" Offset="0"/>
                    <GradientStop Color="#D9080608" Offset="0.42"/>
                    <GradientStop Color="#F2040506" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="980" Height="980" Margin="0,0,-220,0" Opacity="0.12">
            <Border.Background>
                <ImageBrush ImageSource="Assets/BossCamSuite.png" Stretch="Uniform"/>
            </Border.Background>
        </Border>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" CornerRadius="12" Background="{StaticResource ThemePanelBrush}" BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Border Height="126" CornerRadius="12" Margin="0,0,0,12" BorderBrush="#55FF5A1F" BorderThickness="1">
                        <Border.Background>
                            <ImageBrush ImageSource="Assets/BossCamSuite.png" Stretch="UniformToFill" Opacity="0.82"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="BossCamSuite" FontSize="26" FontWeight="SemiBold" Foreground="#FFFFE8DD"/>
                    <TextBlock Text="Infernal Control Surface" Foreground="{StaticResource ThemeTextMutedBrush}" Margin="0,4,0,2"/>
                    <TextBlock Text="Camera Settings" Foreground="#CFD7DE" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="LoadStore_Click">Load Cameras</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="Discover_Click">Discover</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshSelected_Click">Refresh</Button>
                    </WrapPanel>
                    <TextBlock Text="Cameras" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,8"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" DisplayMemberPath="DisplayName" SelectionChanged="Devices_SelectionChanged" Background="#0E171E" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="12" CornerRadius="12" Background="{StaticResource ThemePanelAltBrush}" BorderBrush="#55FF5A1F" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=No camera selected}" FontSize="24" FontWeight="Bold" Foreground="#FFFFE8DD"/>
                        <TextBlock Text="{Binding SelectedDevice.IpAddress, StringFormat=IP: {0}, TargetNullValue=IP: -}" Foreground="{StaticResource ThemeTextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedDeviceFirmwareText, StringFormat=Firmware: {0}}" Foreground="{StaticResource ThemeTextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedDeviceModelText, StringFormat=Model: {0}}" Foreground="{StaticResource ThemeTextMutedBrush}"/>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding DirtyStateText}" FontWeight="SemiBold" Margin="0,0,18,0" Foreground="#FFFFA34D"/>
                            <TextBlock Text="{Binding LastSyncText}" Foreground="#D5DEE7"/>
                            <TextBlock Text="{Binding GroupedApplyIndicator}" Foreground="#D5DEE7" Margin="18,0,0,0"/>
                        </WrapPanel>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshSelected_Click">Refresh</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyValidated_Click">Save Changes</Button>
                        <Button Margin="0,0,8,8" Padding="10,5" Click="ApplyExpert_Click">Advanced Apply</Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Border Padding="10" CornerRadius="12" Background="{StaticResource ThemePanelBrush}" BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1">
                    <TabControl>
                        <TabItem Header="Camera">
                            <StackPanel Margin="8">
                                <TextBlock Text="Camera Identity" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Name" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.DisplayName, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IP Address" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDevice.IpAddress, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Model" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDeviceModelText, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Firmware" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedDeviceFirmwareText, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8" Visibility="{Binding CameraSerialVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Serial" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding CameraSerial, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                                <Grid Margin="0,0,0,8" Visibility="{Binding CameraMacVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MAC" Foreground="#CFD7DE"/>
                                    <TextBox Grid.Column="1" Text="{Binding CameraMac, Mode=OneWay}" IsReadOnly="True"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Image">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageBrightnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Brightness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="{Binding ImageBrightnessMin}" Maximum="{Binding ImageBrightnessMax}" Value="{Binding ImageBrightnessSlider}" IsEnabled="{Binding CanEditImageBrightness}" ToolTip="{Binding ImageBrightnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageBrightness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,8" Foreground="#C4D4E5" Text="{Binding ImageBrightnessBehaviorBadge}" Visibility="{Binding ImageBrightnessVisibility}"/>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageContrastVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Contrast" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageContrastSlider}" IsEnabled="{Binding CanEditImageContrast}" ToolTip="{Binding ImageContrastReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageContrast}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,8" Foreground="#C4D4E5" Text="{Binding ImageContrastBehaviorBadge}" Visibility="{Binding ImageContrastVisibility}"/>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageSaturationVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Saturation" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageSaturationSlider}" IsEnabled="{Binding CanEditImageSaturation}" ToolTip="{Binding ImageSaturationReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageSaturation}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,8" Foreground="#C4D4E5" Text="{Binding ImageSaturationBehaviorBadge}" Visibility="{Binding ImageSaturationVisibility}"/>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageSharpnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sharpness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageSharpnessSlider}" IsEnabled="{Binding CanEditImageSharpness}" ToolTip="{Binding ImageSharpnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageSharpness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,8" Foreground="#C4D4E5" Text="{Binding ImageSharpnessBehaviorBadge}" Visibility="{Binding ImageSharpnessVisibility}"/>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageManualSharpnessVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Manual Sharpness" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ImageManualSharpnessSlider}" IsEnabled="{Binding CanEditImageManualSharpness}" ToolTip="{Binding ImageManualSharpnessReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageManualSharpness}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageHueVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Hue" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageHueSlider}" IsEnabled="{Binding CanEditImageHue}" ToolTip="{Binding ImageHueReadOnlyTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageHue}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageGammaVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gamma" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageGammaSlider}" IsEnabled="{Binding CanEditImageGamma}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageGamma}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageDenoiseVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Denoise" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="5" Value="{Binding ImageDenoiseSlider}" IsEnabled="{Binding CanEditImageDenoise}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageDenoise}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageWdrStrengthVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="WDR Strength" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="1" Maximum="5" Value="{Binding ImageWdrStrengthSlider}" IsEnabled="{Binding CanEditImageWdrStrength}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageWdrStrength}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,8" Foreground="#C4D4E5" Text="{Binding ImageWdrBehaviorBadge}" Visibility="{Binding ImageWdrStrengthVisibility}"/>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageWhiteLightVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="White Light" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageWhiteLightSlider}" IsEnabled="{Binding CanEditImageWhiteLight}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageWhiteLight}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" Visibility="{Binding ImageInfraredVisibility}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Infrared" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImageInfraredSlider}" IsEnabled="{Binding CanEditImageInfrared}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImageInfrared}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Separator Margin="0,10,0,10"/>
